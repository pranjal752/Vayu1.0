# Supabase Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_URL=your_project_url
SUPABASE_ANON_KEY=your_anon_key
CRON_SECRET=your_cron_secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Mapbox Settings
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token
MAPBOX_TOKEN=your_mapbox_token

# API Keys for Data Fetching
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
OPENAQ_API_KEY=your_openaq_api_key
GOOGLE_API_KEY=your_google_api_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# Sentinel Hub (Satellite Imagery)
SENTINEL_HUB_CLIENT_ID=your_sentinel_client_id
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_client_secret

# NASA FIRMS API (Fire Information for Resource Management System)
# Get a free key at: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=your_nasa_firms_key
